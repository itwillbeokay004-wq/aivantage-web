NEXT_PUBLIC_SITE_URL=https://aivantage.es

# Server-only AI generation. Do not expose this with NEXT_PUBLIC_.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Server-only email notifications through Resend.
RESEND_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=

# Optional lead storage through Supabase. Service role stays server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional analytics. Leave blank to disable tracking.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_POSTHOG_KEY=
